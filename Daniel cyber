void encryptFile(const string& inputFile, const string& outputFile, const string& password) {
    // Derive key from password (simple PBKDF2 would be better, but for demo use SHA256)
    uint8_t key[32], iv[16];
    SHA256 sha;
    sha.update(reinterpret_cast<const uint8_t*>(password.data()), password.size());
    sha.final(key);
    // Use a fixed IV for demo (should be random in production)
    memset(iv, 0, 16);

    ifstream in(inputFile, ios::binary);
    if (!in) { cerr << "Cannot open input file.\n"; return; }
    ofstream out(outputFile, ios::binary);
    if (!out) { cerr << "Cannot create output file.\n"; return; }

    // Read file, pad to multiple of 16
    in.seekg(0, ios::end);
    size_t size = in.tellg();
    in.seekg(0);
    size_t paddedSize = ((size + 15) / 16) * 16;
    vector<uint8_t> data(paddedSize, 0);
    in.read(reinterpret_cast<char*>(data.data()), size);
    // PKCS#7 padding
    uint8_t padVal = paddedSize - size;
    for (size_t i = size; i < paddedSize; i++)
        data[i] = padVal;

    AES256 aes(key, iv);
    vector<uint8_t> encrypted(paddedSize);
    aes.EncryptCBC(data.data(), encrypted.data(), paddedSize);

    out.write(reinterpret_cast<char*>(encrypted.data()), paddedSize);
    cout << "File encrypted successfully.\n";
}

void decryptFile(const string& inputFile, const string& outputFile, const string& password) {
    uint8_t key[32], iv[16];
    SHA256 sha;
    sha.update(reinterpret_cast<const uint8_t*>(password.data()), password.size());
    sha.final(key);
    memset(iv, 0, 16);

    ifstream in(inputFile, ios::binary);
    if (!in) { cerr << "Cannot open input file.\n"; return; }
    ofstream out(outputFile, ios::binary);
    if (!out) { cerr << "Cannot create output file.\n"; return; }

    in.seekg(0, ios::end);
    size_t size = in.tellg();
    in.seekg(0);
    if (size % 16 != 0) { cerr << "Invalid encrypted file (size not multiple of 16).\n"; return; }

    vector<uint8_t> data(size);
    in.read(reinterpret_cast<char*>(data.data()), size);

    AES256 aes(key, iv);
    vector<uint8_t> decrypted(size);
    aes.DecryptCBC(data.data(), decrypted.data(), size);

    // Remove PKCS#7 padding
    uint8_t padVal = decrypted[size-1];
    if (padVal > 16) { cerr << "Invalid padding.\n"; return; }
    size_t originalSize = size - padVal;
    out.write(reinterpret_cast<char*>(decrypted.data()), originalSize);
    cout << "File decrypted successfully.\n";
}

// ----------------------------------------------------------------------
// Hash Checker (SHA-256 of file)
// ----------------------------------------------------------------------

string sha256File(const string& filename) {
    ifstream file(filename, ios::binary);
    if (!file) return "";

    SHA256 sha;
    char buffer[4096];
    while (file.read(buffer, sizeof(buffer))) {
        sha.update(reinterpret_cast<uint8_t*>(buffer), file.gcount());
    }
    sha.update(reinterpret_cast<uint8_t*>(buffer), file.gcount());

    uint8_t hash[32];
    sha.final(hash);

    stringstream ss;
    for (int i = 0; i < 32; i++)
        ss << hex << setw(2) << setfill('0') << (int)hash[i];
    return ss.str();
}

// ----------------------------------------------------------------------
// Secure Vault (AES-256 encrypted key-value store)
// ----------------------------------------------------------------------

class SecureVault {
private:
    string filename;
    string password;
    map<string, string> entries;

    bool load() {
        if (!fileExists(filename)) return true; // new vault

        ifstream in(filename, ios::binary);
        if (!in) return false;

        // Read IV and encrypted data
        uint8_t iv[16];
        in.read(reinterpret_cast<char*>(iv), 16);
        vector<uint8_t> encrypted;
        char c;
        while (in.get(c)) encrypted.push_back(c);

        if (encrypted.empty()) return true;

        // Derive key
        uint8_t key[32];
        SHA256 sha;
        sha.update(reinterpret_cast<const uint8_t*>(password.data()), password.size());
        sha.final(key);

        AES256 aes(key, iv);
        vector<uint8_t> decrypted(encrypted.size());
        aes.DecryptCBC(encrypted.data(), decrypted.data(), encrypted.size());

        // Remove padding
        uint8_t padVal = decrypted.back();
        size_t dataSize = decrypted.size() - padVal;

        string data(reinterpret_cast<char*>(decrypted.data()), dataSize);
        stringstream ss(data);
        string line;
        while (getline(ss, line)) {
            size_t pos = line.find('=');
            if (pos != string::npos) {
                string key = line.substr(0, pos);
                string value = line.substr(pos + 1);
                entries[key] = value;
            }
        }
        return true;
    }

    bool save() {
        stringstream plain;
        for (const auto& [k, v] : entries)
            plain << k << "=" << v << "\n";

        string data = plain.str();
        size_t paddedSize = ((data.size() + 15) / 16) * 16;
        vector<uint8_t> padded(paddedSize, 0);
        memcpy(padded.data(), data.data(), data.size());
        uint8_t padVal = paddedSize - data.size();
        for (size_t i = data.size(); i < paddedSize; i++)
            padded[i] = padVal;

        uint8_t iv[16];
        random_device rd;
        for (int i = 0; i < 16; i++) iv[i] = rd() % 256;

        uint8_t key[32];
        SHA256 sha;
        sha.update(reinterpret_cast<const uint8_t*>(password.data()), password.size());
        sha.final(key);

        AES256 aes(key, iv);
        vector<uint8_t> encrypted(paddedSize);
        aes.EncryptCBC(padded.data(), encrypted.data(), paddedSize);

        ofstream out(filename, ios::binary);
        if (!out) return false;
        out.write(reinterpret_cast<char*>(iv), 16);
        out.write(reinterpret_cast<char*>(encrypted.data()), encrypted.size());
        return true;
    }

public:
    SecureVault(const string& fname, const string& pwd) : filename(fname), password(pwd) {
        load();
    }

    void set(const string& key, const string& value) {
        entries[key] = value;
        save();
    }

    string get(const string& key) {
        auto it = entries.find(key);
        if (it != entries.end()) return it->second;
        return "";
    }

    void list() {
        for (const auto& [k, v] : entries)
            cout << k << " : " << v << endl;
    }

    bool remove(const string& key) {
        auto it = entries.find(key);
        if (it != entries.end()) {
            entries.erase(it);
            save();
            return true;
        }
        return false;
    }
};

// ----------------------------------------------------------------------
// Port Scanner (multi-threaded TCP connect)
// ----------------------------------------------------------------------

class PortScanner {
private:
    string target;
    int startPort, endPort;
    int timeoutMs;
    vector<int> openPorts;
    mutex mtx;

    bool scanPort(int port) {
        int sock = socket(AF_INET, SOCK_STREAM, 0);
        if (sock < 0) return false;

        // Set non-blocking
        fcntl(sock, F_SETFL, O_NONBLOCK);

        sockaddr_in addr;
        addr.sin_family = AF_INET;
        addr.sin_port = htons(port);
        inet_pton(AF_INET, target.c_str(), &addr.sin_addr);

        connect(sock, (sockaddr*)&addr, sizeof(addr));
        fd_set fdset;
        FD_ZERO(&fdset);
        FD_SET(sock, &fdset);
        timeval tv;
        tv.tv_sec = timeoutMs / 1000;
        tv.tv_usec = (timeoutMs % 1000) * 1000;

        if (select(sock + 1, NULL, &fdset, NULL, &tv) == 1) {
            int so_error;
            socklen_t len = sizeof(so_error);
            getsockopt(sock, SOL_SOCKET, SO_ERROR, &so_error, &len);
            if (so_error == 0) {
                close(sock);
                return true;
            }
        }
        close(sock);
        return false;
    }

public:
    PortScanner(const string& ip, int start, int end, int timeout = 2000)
        : target(ip), startPort(start), endPort(end), timeoutMs(timeout) {}

    void scan() {
        vector<thread> threads;
        atomic<int> currentPort(startPort);

        for (int i = 0; i < 100; ++i) { // 100 threads
            threads.emplace_back([&]() {
                while (true) {
                    int port = currentPort.fetch_add(1);
                    if (port > endPort) break;
                    if (scanPort(port)) {
                        lock_guard<mutex> lock(mtx);
                        openPorts.push_back(port);
                        cout << "Port " << port << " is open.\n";
                    }
                }
            });
        }

        for (auto& t : threads)
            t.join();
    }

    vector<int> getOpenPorts() { return openPorts; }
};

// ----------------------------------------------------------------------
// Network Scanner (ICMP ping sweep)
// ----------------------------------------------------------------------

bool pingHost(const string& ip, int timeoutMs = 1000) {
    int sock = socket(AF_INET, SOCK_RAW, IPPROTO_ICMP);
    if (sock < 0) {
        // Need root
        return false;
    }

    struct icmphdr icmp;
    icmp.type = ICMP_ECHO;
    icmp.code = 0;
    icmp.checksum = 0;
    icmp.un.echo.id = getpid() & 0xFFFF;
    icmp.un.echo.sequence = 1;

    sockaddr_in addr;
    addr.sin_family = AF_INET;
    inet_pton(AF_INET, ip.c_str(), &addr.sin_addr);

    struct timeval tv;
    tv.tv_sec = timeoutMs / 1000;
    tv.tv_usec = (timeoutMs % 1000) * 1000;
    setsockopt(sock, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));

    if (sendto(sock, &icmp, sizeof(icmp), 0, (sockaddr*)&addr, sizeof(addr)) <= 0) {
        close(sock);
        return false;
    }

    char buffer[1024];
    sockaddr_in sender;
    socklen_t senderLen = sizeof(sender);
    ssize_t len = recvfrom(sock, buffer, sizeof(buffer), 0, (sockaddr*)&sender, &senderLen);
    close(sock);
    return len > 0;
}

void networkScan(const string& subnet, int timeoutMs = 1000) {
    // subnet like "192.168.1."
    vector<thread> threads;
    for (int i = 1; i < 255; ++i) {
        string ip = subnet + to_string(i);
        threads.emplace_back([ip, timeoutMs]() {
            if (pingHost(ip, timeoutMs))
                cout << "Host " << ip << " is alive.\n";
        });
    }
    for (auto& t : threads) t.join();
}

