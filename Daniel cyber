void startSniffer(const string& interface) {
    char errbuf[PCAP_ERRBUF_SIZE];
    pcap_t* handle = pcap_open_live(interface.c_str(), BUFSIZ, 1, 1000, errbuf);
    if (!handle) {
        cerr << "pcap_open_live failed: " << errbuf << endl;
        return;
    }

    struct bpf_program fp;
    char filter_exp[] = "ip";  // Capture only IP packets
    if (pcap_compile(handle, &fp, filter_exp, 0, PCAP_NETMASK_UNKNOWN) == -1) {
        cerr << "Couldn't parse filter " << filter_exp << ": " << pcap_geterr(handle) << endl;
        pcap_close(handle);
        return;
    }
    if (pcap_setfilter(handle, &fp) == -1) {
        cerr << "Couldn't install filter: " << pcap_geterr(handle) << endl;
        pcap_close(handle);
        return;
    }

    cout << "Sniffing on interface " << interface << ". Press Ctrl+C to stop.\n";
    pcap_loop(handle, 0, packetHandler, nullptr);
    pcap_close(handle);
}
