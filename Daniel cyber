// ----------------------------------------------------------------------
// Utility Functions
// ----------------------------------------------------------------------

string trim(const string& str) {
    size_t first = str.find_first_not_of(" \t\n\r");
    if (first == string::npos) return "";
    size_t last = str.find_last_not_of(" \t\n\r");
    return str.substr(first, last - first + 1);
}

vector<string> split(const string& s, char delim) {
    vector<string> tokens;
    stringstream ss(s);
    string item;
    while (getline(ss, item, delim))
        tokens.push_back(item);
    return tokens;
}

bool fileExists(const string& path) {
    return filesystem::exists(path);
}

string execCommand(const string& cmd) {
    array<char, 128> buffer;
    string result;
    unique_ptr<FILE, decltype(&pclose)> pipe(popen(cmd.c_str(), "r"), pclose);
    if (!pipe) return "";
    while (fgets(buffer.data(), buffer.size(), pipe.get()) != nullptr)
        result += buffer.data();
    return result;
}

// ----------------------------------------------------------------------
// AES-256 Implementation (from small AES, public domain)
// ----------------------------------------------------------------------

class AES256 {
private:
    static const uint8_t sbox[256];
    static const uint8_t rsbox[256];
    static const uint8_t Rcon[11];

    uint8_t RoundKey[240];
    uint8_t Iv[16];

    void KeyExpansion(const uint8_t* key) {
        // Standard AES key expansion for 256-bit key
        uint32_t *w = (uint32_t*)RoundKey;
        for (int i = 0; i < 8; i++) w[i] = (key[4*i]<<24)|(key[4*i+1]<<16)|(key[4*i+2]<<8)|key[4*i+3];
        for (int i = 8; i < 60; i++) {
            uint32_t temp = w[i-1];
            if (i % 8 == 0) {
                temp = (temp<<8)|(temp>>24);
                uint8_t a[4] = {uint8_t(temp>>24), uint8_t(temp>>16), uint8_t(temp>>8), uint8_t(temp)};
                a[0] = sbox[a[0]] ^ Rcon[i/8];
                a[1] = sbox[a[1]];
                a[2] = sbox[a[2]];
                a[3] = sbox[a[3]];
                temp = (a[0]<<24)|(a[1]<<16)|(a[2]<<8)|a[3];
            } else if (i % 8 == 4) {
                uint8_t a[4] = {uint8_t(temp>>24), uint8_t(temp>>16), uint8_t(temp>>8), uint8_t(temp)};
                a[0] = sbox[a[0]];
                a[1] = sbox[a[1]];
                a[2] = sbox[a[2]];
                a[3] = sbox[a[3]];
                temp = (a[0]<<24)|(a[1]<<16)|(a[2]<<8)|a[3];
            }
            w[i] = w[i-8] ^ temp;
        }
    }

    void AddRoundKey(uint8_t state[16], int round) {
        for (int i = 0; i < 16; i++)
            state[i] ^= RoundKey[round*16 + i];
    }

    void SubBytes(uint8_t state[16]) {
        for (int i = 0; i < 16; i++)
            state[i] = sbox[state[i]];
    }

    void ShiftRows(uint8_t state[16]) {
        uint8_t tmp[16];
        tmp[0] = state[0]; tmp[1] = state[5]; tmp[2] = state[10]; tmp[3] = state[15];
        tmp[4] = state[4]; tmp[5] = state[9]; tmp[6] = state[14]; tmp[7] = state[3];
        tmp[8] = state[8]; tmp[9] = state[13]; tmp[10] = state[2]; tmp[11] = state[7];
        tmp[12] = state[12]; tmp[13] = state[1]; tmp[14] = state[6]; tmp[15] = state[11];
        memcpy(state, tmp, 16);
    }

    void MixColumns(uint8_t state[16]) {
        for (int i = 0; i < 4; i++) {
            uint8_t a0 = state[i*4];
            uint8_t a1 = state[i*4+1];
            uint8_t a2 = state[i*4+2];
            uint8_t a3 = state[i*4+3];
            state[i*4]   = (uint8_t)(gmul(a0,2) ^ gmul(a1,3) ^ a2 ^ a3);
            state[i*4+1] = (uint8_t)(a0 ^ gmul(a1,2) ^ gmul(a2,3) ^ a3);
            state[i*4+2] = (uint8_t)(a0 ^ a1 ^ gmul(a2,2) ^ gmul(a3,3));
            state[i*4+3] = (uint8_t)(gmul(a0,3) ^ a1 ^ a2 ^ gmul(a3,2));
        }
    }

    uint8_t gmul(uint8_t a, uint8_t b) {
        uint8_t p = 0;
        for (int i = 0; i < 8; i++) {
            if (b & 1) p ^= a;
            a = (a & 0x80) ? (a << 1) ^ 0x1b : a << 1;
            b >>= 1;
        }
        return p;
    }

    void InvSubBytes(uint8_t state[16]) {
        for (int i = 0; i < 16; i++)
            state[i] = rsbox[state[i]];
    }

    void InvShiftRows(uint8_t state[16]) {
        uint8_t tmp[16];
        tmp[0] = state[0]; tmp[1] = state[13]; tmp[2] = state[10]; tmp[3] = state[7];
        tmp[4] = state[4]; tmp[5] = state[1]; tmp[6] = state[14]; tmp[7] = state[11];
        tmp[8] = state[8]; tmp[9] = state[5]; tmp[10] = state[2]; tmp[11] = state[15];
        tmp[12] = state[12]; tmp[13] = state[9]; tmp[14] = state[6]; tmp[15] = state[3];
        memcpy(state, tmp, 16);
    }

    void InvMixColumns(uint8_t state[16]) {
        for (int i = 0; i < 4; i++) {
            uint8_t a0 = state[i*4];
            uint8_t a1 = state[i*4+1];
            uint8_t a2 = state[i*4+2];
            uint8_t a3 = state[i*4+3];
            state[i*4]   = (uint8_t)(gmul(a0,14) ^ gmul(a1,11) ^ gmul(a2,13) ^ gmul(a3,9));
            state[i*4+1] = (uint8_t)(gmul(a0,9) ^ gmul(a1,14) ^ gmul(a2,11) ^ gmul(a3,13));
            state[i*4+2] = (uint8_t)(gmul(a0,13) ^ gmul(a1,9) ^ gmul(a2,14) ^ gmul(a3,11));
            state[i*4+3] = (uint8_t)(gmul(a0,11) ^ gmul(a1,13) ^ gmul(a2,9) ^ gmul(a3,14));
        }
    }

    void Cipher(uint8_t block[16]) {
        AddRoundKey(block, 0);
        for (int round = 1; round < 14; round++) {
            SubBytes(block);
            ShiftRows(block);
            MixColumns(block);
            AddRoundKey(block, round);
        }
        SubBytes(block);
        ShiftRows(block);
        AddRoundKey(block, 14);
    }

    void InvCipher(uint8_t block[16]) {
        AddRoundKey(block, 14);
        for (int round = 13; round > 0; round--) {
            InvShiftRows(block);
            InvSubBytes(block);
            AddRoundKey(block, round);
            InvMixColumns(block);
        }
        InvShiftRows(block);
        InvSubBytes(block);
        AddRoundKey(block, 0);
    }

    void XORWithIv(uint8_t* data, int len) {
        for (int i = 0; i < len; i++)
            data[i] ^= Iv[i % 16];
    }

public:
    AES256(const uint8_t* key, const uint8_t* iv) {
        KeyExpansion(key);
        memcpy(Iv, iv, 16);
    }

    void EncryptCBC(uint8_t* input, uint8_t* output, size_t len) {
        // len must be multiple of 16
        for (size_t i = 0; i < len; i += 16) {
            for (int j = 0; j < 16; j++)
                input[i+j] ^= Iv[j];
            Cipher(input + i);
            memcpy(output + i, input + i, 16);
            memcpy(Iv, output + i, 16);
        }
    }

    void DecryptCBC(uint8_t* input, uint8_t* output, size_t len) {
        uint8_t lastIv[16];
        memcpy(lastIv, Iv, 16);
        for (size_t i = 0; i < len; i += 16) {
            memcpy(Iv, input + i, 16);
            memcpy(output + i, input + i, 16);
            InvCipher(output + i);
            for (int j = 0; j < 16; j++)
                output[i+j] ^= lastIv[j];
            memcpy(lastIv, input + i, 16);
        }
        memcpy(Iv, lastIv, 16);
    }
};

